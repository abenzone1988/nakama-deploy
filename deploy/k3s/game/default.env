# 默认配置（各游戏 .env 可覆盖）
# 镜像仓库与节点 IP（用于输出访问地址）
REGISTRY=192.168.102.224:30500
REGISTRY_IP=192.168.102.224

# nakama 副本数
REPLICAS=2

# NodePort 端口（每游戏需不同，范围 30000-32767）
NODE_PORT_SOCKET=30735
NODE_PORT_GRPC=30734
NODE_PORT_CONSOLE=30751

# 安全相关（生产务必修改）
SERVER_KEY=sparkgame
ENCRYPTION_KEY=defaultencryptionkey
REFRESH_ENCRYPTION_KEY=defaultrefreshencryptionkey

# 控制台
CONSOLE_USER=admin
CONSOLE_PASSWORD=password
